{
  "entities": {
    "Deployment": {
      "title": "Site Deployment",
      "description": "Represents a hosted website on the Shadow-Net network.",
      "type": "object",
      "properties": {
        "deploymentId": { "type": "string", "description": "Unique ID of the deployment." },
        "siteName": { "type": "string", "description": "The user-defined name of the site." },
        "fullDomain": { "type": "string", "description": "The generated .com domain." },
        "content": { "type": "string", "description": "The HTML/Source content of the site." },
        "ownerId": { "type": "string", "description": "UID of the user who deployed it." },
        "createdAt": { "type": "string", "format": "date-time" },
        "visitorCount": { "type": "integer", "description": "Simulated traffic." },
        "status": { "type": "string", "enum": ["live", "offline"], "description": "Current network status." }
      },
      "required": ["deploymentId", "siteName", "fullDomain", "content", "ownerId", "createdAt", "status"]
    }
  },
  "firestore": {
    "deployments": {
      "schema": "Deployment",
      "description": "Master registry of all hosted shadow sites."
    }
  }
}
